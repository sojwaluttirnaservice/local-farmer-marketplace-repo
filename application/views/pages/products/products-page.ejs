<!-- This is just for referecne, copy this layout for company pages -->

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%>

        <!-- Company common links -->

        <!-- Common scripts -->
        <%-include("../../common/common-scripts.ejs")%>

        <!-- Company common scripts -->
        <%- include("../../common/common-user-scripts.ejs")%>

        <script src="/javascripts/handlers/cart/cartHandler.js" type="module" defer></script>

        <script
            src="/javascripts/handlers/products/productPageHandler.js"
            type="module"
            defer></script>
    </head>
    <body>
        <% if(typeof user !== 'undefined' && typeof user != null) {%>
        <%-include("../../components/navs/outside-navbar.ejs")%> <% } else {%>
        <%-include("../../components/navs/outside-navbar.ejs")%> <% } %>

        <main>
            <section class="section my-8">
                <div class="grid grid-cols-8 relative">
                    <!-- LEFT PART -->
                    <div class="left filters-list-half col-span-2 sticky top-0">
                        <aside class="px-8">
                            <h3 class="text-xl font-semibold mb-4">Filters</h3>

                            <% let categories = ["Vegetables", "Fruits", "Grains", "Dairy",
                            "Spices", "Pulses", "Others"]; %>
                            <ul
                                id="filters-list"
                                class="space-y-3 bg-white p-4 rounded-lg shadow-md"
                                data-totalCategories="<%=categories.length %>">
                                <% categories.forEach(category => { %>
                                <li
                                    class="flex items-center space-x-2 p-2 hover:bg-gray-100 rounded-md transition duration-300">
                                    <input
                                        data-role="category-filter-checkbox"
                                        data-category="<%= category %>"
                                        type="checkbox"
                                        id="<%= category %>"
                                        class="h-5 w-5 text-blue-600 border-gray-300 rounded focus:ring focus:ring-blue-500 focus:ring-opacity-50" />
                                    <label
                                        for="<%= category %>"
                                        class="text-gray-700 font-medium cursor-pointer">
                                        <%= category %>
                                    </label>
                                </li>
                                <% }) %>
                            </ul>
                        </aside>
                    </div>

                    <!-- RIGHT PART -->
                    <div class="right-part products-list-half col-span-6">
                        <div class="px-8">
                            <ul
                                id="products-list"
                                class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                                <% products.forEach((featuredProduct) => { %>
                                <li
                                    data-productCategory="<%= featuredProduct.category %>"
                                    class="bg-white p-6 rounded-lg shadow hover:shadow-2xl transition">
                                    <div
                                        class="aspect-square overflow-hidden flex items-center justify-center rounded-md">
                                        <img
                                            src="<%= productImageUrl %>/<%= featuredProduct.image_name %>"
                                            alt="<%= featuredProduct.image_name %>"
                                            onerror="this.src='https://i.pinimg.com/736x/9c/25/85/9c258525e4eb471d29b3c0a2c22d000b.jpg'"
                                            class="w-full rounded" />
                                    </div>
                                    <h3 class="text-lg font-semibold mt-4">
                                        <%= featuredProduct.product_name %>
                                    </h3>
                                    <p class="text-gray-600">
                                        <%= featuredProduct.selling_price_per_unit %> per <%=
                                        featuredProduct.unit_of_measurement %>
                                        <span class="font-bold">INR</span>
                                    </p>

                                    <div>
                                        <div
                                            class="inline-block px-3 py-1 text-xs font-semibold text-white uppercase rounded-full shadow-md <% if (featuredProduct.category === 'Vegetables') { %> bg-green-500 <% } %> <% if (featuredProduct.category === 'Fruits') { %> bg-orange-500 <% } %> <% if (featuredProduct.category === 'Grains') { %> bg-yellow-600 <% } %> <% if (featuredProduct.category === 'Dairy') { %> bg-blue-500 <% } %> <% if (featuredProduct.category === 'Spices') { %> bg-red-500 <% } %> <% if (featuredProduct.category === 'Pulses') { %> bg-purple-500 <% } %> <% if (featuredProduct.category === 'Others') { %> bg-gray-500 <% } %>">
                                            <%= featuredProduct.category %>
                                        </div>
                                    </div>

                                    <div>
                                        <div class="mt-8">
                                            <div class="flex items-center justify-between gap-2">
                                                <button
                                                    data-role="add-to-cart-btn"
                                                    data-productId="<%=featuredProduct.id %>"
                                                    data-pricePerUnit= "<%=featuredProduct.selling_price_per_unit %>"
                                                    data-unitOfMeasurement="<%=featuredProduct.unit_of_measurement %>"
                                                    data-productName="<%=featuredProduct.product_name %>"
                                                    data-productImageUrl="<%=productImageUrl %>/<%=featuredProduct.image_name %>"
                                                    data-userId="<%=user?.id %>"
                                                    type="button"
                                                    data-targetCountId="target-count_<%= featuredProduct.id %>"
                                                    data-addQuantity="-1"
                                                    class="w-16 bg-rose-800 hover:bg-rose-900 text-white py-2 font-extrabold rounded-sm">
                                                    <i class="fa-solid fa-minus"></i>
                                                </button>

                                                <span
                                                    data-productId="<%=featuredProduct.id %>"
                                                    data-userId="<%=user?.id %>"
                                                    type="button"
                                                    id="target-count_<%= featuredProduct.id %>"
                                                    class="w-full text-center rounded-lg font-bold">
                                                    0
                                                </span>

                                                <button
                                                    data-role="add-to-cart-btn"
                                                    data-productId="<%=featuredProduct.id %>"
                                                    data-pricePerUnit= "<%=featuredProduct.selling_price_per_unit %>"
                                                    data-unitOfMeasurement="<%=featuredProduct.unit_of_measurement %>"
                                                    data-productName="<%=featuredProduct.product_name %>"
                                                    data-productImageUrl="<%=productImageUrl %>/<%=featuredProduct.image_name %>"
                                                    data-userId="<%=user?.id %>"
                                                    type="button"
                                                    data-targetCountId="target-count_<%= featuredProduct.id %>"
                                                    data-addQuantity="1"
                                                    class="w-16 bg-green-600 hover:bg-green-700 text-white py-2 font-extrabold rounded-sm">
                                                    <i class="fa-solid fa-plus"></i>
                                                </button>
                                            </div>
                                        </div>

                                        <div hidden class="add-to-cart-btn-holder">
                                            <button
                                                data-role="add-to-cart-btn"
                                                data-productId="<%=featuredProduct.id %>"
                                                data-pricePerUnit= "<%=featuredProduct.selling_price_per_unit %>"
                                                data-unitOfMeasurement="<%=featuredProduct.unit_of_measurement %>"
                                                data-productName="<%=featuredProduct.product_name %>"
                                                data-productImageUrl="<%=productImageUrl %>/<%=featuredProduct.image_name %>"
                                                data-userId="<%=user?.id %>"
                                                type="button"
                                                data-addQuantity="1"
                                                class="w-full bg-green-600 hover:bg-green-700 text-white py-2 rounded-lg">
                                                Add to Cart
                                            </button>
                                        </div>
                                    </div>
                                </li>
                                <% }) %>
                            </ul>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <!-- Footer -->

        <%-include("../../components/footers/outside-footer.ejs")%>
    </body>
</html>
