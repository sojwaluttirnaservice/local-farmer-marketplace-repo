<!-- This is just for referecne, copy this layout for company pages -->

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%>

        <!-- Admin common links -->
        <%- include("../../common/common-admin-links.ejs")%>

        <!-- Company common links -->

        <!-- Common scripts -->
        <%-include("../../common/common-scripts.ejs")%>

        <!-- Admin common scripts -->

        <%- include("../../common/common-admin-scripts.ejs")%>

        <script
            src="/javascripts/handlers/products/addPredefinedProductHandler.js"
            type="module"
            defer></script>
    </head>
    <body>
        <% if (admin != null && admin !== undefined) { %> <%-
        include("../../components/navs/admin-navbar.ejs") %> <% } %>

        <main>
   

            <section
                data-role="page-heading"
                class="flex items-center justify-between py-4 px-6 bg-white shadow-md rounded-md">
                <!-- 🔙 Back Button -->
                <button
                    onclick="window.history.back()"
                    class="flex items-center text-gray-700 hover:text-blue-600 font-semibold transition duration-300">
                    <i class="fas fa-arrow-left mr-2"></i> Back
                </button>

                <!-- 📌 Page Title -->
                <h2
                    class="text-3xl font-extrabold text-gray-800 tracking-wide relative text-center flex-grow">
                    <% if (admin != null && admin !== undefined) { %> Add Product<% }else { %> Add
                        Product <% }%>
                    <span class="block h-1 w-16 bg-blue-500 mx-auto mt-2 rounded-full"></span>
                </h2>

                <!-- Placeholder for Alignment (Keeps title centered) -->
                <div class="w-20"></div>
            </section>

            <!-- Section: Form to Add Predefined Product -->
            <section class="p-4 flex justify-center items-center">
                <form
                    class="w-full max-w-lg bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4"
                    id="add-predefined-product-form"
                    >
                    <!-- <h2 class="block text-gray-700 text-2xl font-bold mb-6 text-center">
                        Add Predefined Product
                    </h2> -->

                    <!-- Product Name -->
                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="product_name">
                            Product Name
                        </label>
                        <input
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2"
                            id="product_name"
                            name="product_name"
                            type="text"
                            placeholder="Enter product name"
                            required />
                    </div>


                     <!-- Price per Unit -->
                     <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="product_photo">
                            Add Product Image 
                        </label>
                        <input
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2"
                            id="product_photo"
                            name="product_photo"
                            type="file"
                            accept="image/*"
                            placeholder="Enter Selling price per unit"
                            required />
                    </div>

                    <!-- Description -->
                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="description">
                            Description
                        </label>
                        <textarea
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2"
                            id="description"
                            name="description"
                            placeholder="Enter description"></textarea>
                    </div>

                    <!-- Price per Unit -->
                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="price_per_unit">
                            Price per Unit
                        </label>
                        <input
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2"
                            id="price_per_unit"
                            name="price_per_unit"
                            type="number"
                            step="0.01"
                            placeholder="Enter price per unit"
                            required />
                    </div>

                    <!-- Price per Unit -->
                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="selling_price_per_unit">
                            Selling Price per Unit
                        </label>
                        <input
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2"
                            id="selling_price_per_unit"
                            name="selling_price_per_unit"
                            type="number"
                            step="0.01"
                            placeholder="Enter Selling price per unit"
                            required />
                    </div>


                    <!-- Category -->
                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="category">
                            Category
                        </label>
                        <select
                            id="category"
                            name="category"
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2"
                            required>
                            <option value="">Select Category</option>
                            <option value="Vegetables">Vegetables</option>
                            <option value="Fruits">Fruits</option>
                            <option value="Grains">Grains</option>
                            <option value="Dairy">Dairy</option>
                            <option value="Spices">Spices</option>
                            <option value="Pulses">Pulses</option>
                            <option value="Others">Others</option>
                        </select>
                    </div>

                    <!-- Unit of Measurement -->
                    <div class="mb-6">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="unit_of_measurement">
                            Unit of Measurement
                        </label>
                        <select
                            id="unit_of_measurement"
                            name="unit_of_measurement"
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2"
                            required>
                            <option value="">Select Unit</option>
                            <option value="Kilogram">Kilogram</option>
                            <option value="Gram">Gram</option>
                            <option value="Dozen">Dozen</option>
                            <option value="Liter">Liter</option>
                            <option value="Piece">Piece</option>
                            <option value="Quintal">Quintal</option>
                        </select>
                    </div>

                    <!-- Submit Button -->
                    <div class="flex items-center justify-center">
                        <button
                            type="button"
                            id='add-predefined-product-btn'
                            class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded focus:outline-none focus:shadow-outline"
                            type="submit">
                            Add Product
                        </button>
                    </div>
                </form>
            </section>

            <!-- Section: Predefined Products List Table -->
            <section class="p-6 bg-white shadow-md rounded-lg">
                <h2 class="text-2xl font-bold mb-4 text-center text-gray-900">Predefined Products List</h2>
            
                <div class="overflow-x-auto">
                    <table class="min-w-full bg-white border border-gray-200 shadow-md rounded-lg">
                        <!-- Table Head -->
                        <thead class="bg-green-600 text-white">
                            <tr>
                                <th class="px-4 py-3 text-left text-sm font-medium">#</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Product</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Description</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Price/Unit</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Selling Price</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Category</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Unit</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Created At</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Updated At</th>
                            </tr>
                        </thead>
            
                        <!-- Table Body -->
                        <tbody class="divide-y divide-gray-200 bg-gray-50">
                            <% if(predefinedProductsList && predefinedProductsList.length > 0) { %>
                                <% predefinedProductsList.forEach((product, index) => { %>
                                    <tr class="hover:bg-green-100 transition duration-200">
                                        <!-- Serial Number -->
                                        <td class="px-4 py-3 text-sm text-gray-700"><%= index + 1 %></td>
            
                                        <!-- Product Image & Name -->
                                        <td class="px-4 py-3 border-b">
                                            <div class="flex items-center gap-3">
                                                <img class="w-12 h-12 rounded-md border border-gray-300 shadow-sm" 
                                                     src="<%= productImageUrl %>/<%= product.image_name %>" 
                                                     alt="<%= product.product_name %>"
                                                     onerror="this.src='https://i.pinimg.com/736x/9c/25/85/9c258525e4eb471d29b3c0a2c22d000b.jpg'">
                                                <span class="font-medium text-gray-900">
                                                    <%= product.product_name %> (<%= product.id %>)
                                                </span>
                                            </div>
                                        </td>
            
                                        <!-- Description -->
                                        <td class="px-4 py-3 text-sm text-gray-700"><%= product.description %></td>
            
                                        <!-- Price per Unit -->
                                        <td class="px-4 py-3 text-sm font-semibold text-gray-700">₹<%= product.price_per_unit %></td>
            
                                        <!-- Selling Price per Unit -->
                                        <td class="px-4 py-3 text-sm font-semibold text-gray-700">₹<%= product.selling_price_per_unit %></td>
            
                                        <!-- Category -->
                                        <td class="px-4 py-3 text-sm text-gray-700 capitalize"><%= product.category %></td>
            
                                        <!-- Unit of Measurement -->
                                        <td class="px-4 py-3 text-sm text-gray-700 capitalize"><%= product.unit_of_measurement %></td>
            
                                        <!-- Created At -->
                                        <td class="px-4 py-3 text-sm text-gray-600"><%= product._createdAt %></td>
            
                                        <!-- Updated At -->
                                        <td class="px-4 py-3 text-sm text-gray-600"><%= product._updatedAt %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <!-- No Data Found Row -->
                                <tr>
                                    <td colspan="9" class="py-4 px-6 text-center text-gray-500 font-medium">No products found</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </section>
            
        </main>
    </body>
</html>
