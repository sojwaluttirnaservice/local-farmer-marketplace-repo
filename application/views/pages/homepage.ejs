<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <%- include("../common/common-links.ejs")%>
        <!-- Common user links -->
        <%-include("../common/common-user-links.ejs")%>
        <!-- Common scripts -->
        <%-include("../common/common-scripts.ejs")%>

        <script src="/javascripts/handlers/auth/authHandler.js" type="module" defer></script>
    </head>

    <body class="bg-gray-100 text-gray-800">
        <%-include ("../components/navs/user-navbar.ejs") %>

        <main>
            <!-- Hero Section -->
            <section
                class="relative w-full h-screen bg-cover bg-center"
                style="
                    background-image: url('/assets/images/home-hero.jpg');
                    background-size: cover;
                    background-repeat: no-repeat;
                ">
                <div
                    class="absolute inset-0 bg-black/40 bg-opacity-50 flex flex-col items-center justify-center text-center px-6">
                    <h1 class="text-white text-6xl font-extrabold">Save Food, Feed Lives</h1>
                    <p class="text-xl text-gray-200 mt-4 font-semibold">
                        Join us in the mission to reduce food waste and help those in need.
                    </p>
                    <a
                        href="/donate"
                        class="mt-6 px-8 py-4 bg-green-600 text-white text-lg font-bold rounded-lg shadow-lg hover:bg-green-700 transition duration-300"
                        >Get Involved</a
                    >
                </div>
            </section>

            <!-- Mission Section -->
            <section class="py-20 text-center bg-white">
                <h2 class="text-4xl font-extrabold text-green-700">Our Mission</h2>
                <p class="mt-6 text-lg text-gray-600 max-w-3xl mx-auto font-medium">
                    We aim to bridge the gap between excess food and those in need by partnering
                    with individuals and businesses to redistribute surplus food.
                </p>
            </section>

            <!-- Impact Section -->
            <section class="bg-gray-200 py-20 text-center">
                <h2 class="text-4xl font-extrabold text-green-700">Our Impact</h2>
                <div class="mt-10 flex flex-wrap justify-center gap-10">
                    <div class="w-72 bg-white p-8 shadow-lg rounded-lg">
                        <h3 class="text-2xl font-bold">Food Rescued</h3>
                        <p class="text-green-600 text-3xl font-extrabold">500,000+ kg</p>
                    </div>
                    <div class="w-72 bg-white p-8 shadow-lg rounded-lg">
                        <h3 class="text-2xl font-bold">Meals Served</h3>
                        <p class="text-green-600 text-3xl font-extrabold">1,000,000+</p>
                    </div>
                    <div class="w-72 bg-white p-8 shadow-lg rounded-lg">
                        <h3 class="text-2xl font-bold">Volunteers</h3>
                        <p class="text-green-600 text-3xl font-extrabold">10,000+</p>
                    </div>
                </div>
            </section>

            <!-- How It Works -->
            <section class="py-20 text-center bg-white">
                <h2 class="text-4xl font-extrabold text-green-700">How It Works</h2>
                <div class="mt-10 flex flex-wrap justify-center gap-10">
                    <div class="w-72 bg-gray-100 p-8 shadow-lg rounded-lg">
                        <h3 class="text-2xl font-bold">Step 1</h3>
                        <p class="text-gray-700 font-medium">
                            Businesses & individuals donate surplus food.
                        </p>
                    </div>
                    <div class="w-72 bg-gray-100 p-8 shadow-lg rounded-lg">
                        <h3 class="text-2xl font-bold">Step 2</h3>
                        <p class="text-gray-700 font-medium">
                            Food is stored and distributed safely.
                        </p>
                    </div>
                    <div class="w-72 bg-gray-100 p-8 shadow-lg rounded-lg">
                        <h3 class="text-2xl font-bold">Step 3</h3>
                        <p class="text-gray-700 font-medium">Meals reach those in need.</p>
                    </div>
                </div>
            </section>

            <!-- Call to Action -->
            <section class="bg-green-600 text-white py-20 text-center">
                <h2 class="text-4xl font-extrabold">Make a Difference Today</h2>
                <p class="mt-6 text-xl font-semibold">
                    Your contribution can save lives and reduce waste.
                </p>
                <div class="mt-10">
                    <a
                        href="/donate"
                        class="px-8 py-4 bg-white text-green-600 text-lg font-bold rounded-lg shadow-lg hover:bg-gray-100 transition duration-300"
                        >Donate Now</a
                    >
                </div>
            </section>
        </main>

        <!-- Footer -->
        <footer class="bg-gray-900 text-white text-center py-8 mt-20">
            <p class="text-lg font-medium">
                &copy; 2025 Waste Food Management. All Rights Reserved.
            </p>
        </footer>
    </body>
</html>
