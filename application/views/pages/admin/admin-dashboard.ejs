<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%> <%-
        include("../../common/common-admin-links.ejs")%> <%-
        include("../../common/common-scripts.ejs")%> <%-
        include("../../common/common-admin-scripts.ejs")%>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    </head>
    <body class="bg-gray-50">
        <%- include("../../components/navs/admin-navbar.ejs")%>

        <main class="p-6">
            <div class="max-w-7xl mx-auto">
                <!-- Dashboard Header -->
                <h1 class="text-4xl font-bold text-gray-800 mb-8 text-center">Admin Dashboard</h1>

                <!-- Stats Section -->
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                    <% Object.entries(stats).forEach(([key, value]) => { %>
                    <div
                        class="bg-white shadow-lg rounded-xl p-6 text-center transform transition duration-300 hover:scale-105">
                        <h2 class="text-lg font-semibold text-gray-600 tracking-wide">
                            <%= key.replace('_', ' ').toUpperCase() %>
                        </h2>
                        <p class="text-3xl font-extrabold text-blue-600 mt-2"><%= value %></p>
                    </div>
                    <% }); %>
                </div>

                <!-- Most Donated Foods Chart -->
                <div class="mt-10 bg-white shadow-lg rounded-xl p-6">
                    <h2 class="text-2xl font-semibold text-gray-800 mb-6 text-center">
                        Top Donated Food Categories
                    </h2>
                    <canvas id="donationsChart"></canvas>
                </div>
            </div>
        </main>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const ctx = document.getElementById("donationsChart").getContext("2d");
                const mostDonatedFoods = <%- JSON.stringify(mostDonatedFoods) %>;

                new Chart(ctx, {
                    type: "bar",
                    data: {
                        labels: mostDonatedFoods.map(item => item.category_name),
                        datasets: [{
                            label: "Donations Count",
                            data: mostDonatedFoods.map(item => item.donation_count),
                            backgroundColor: ["#4F46E5", "#2563EB", "#10B981", "#F59E0B", "#EF4444"],
                            borderColor: "#1E3A8A",
                            borderWidth: 1.5,
                        }],
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: { beginAtZero: true, grid: { color: "#E5E7EB" } },
                            x: { grid: { color: "#E5E7EB" } }
                        },
                        plugins: {
                            legend: { display: false }
                        }
                    },
                });
            });
        </script>
    </body>
</html>
