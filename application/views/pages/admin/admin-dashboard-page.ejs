<!-- This is just for referecne, copy this layout for company pages -->

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%>

        <!-- Admin common links -->
        <%- include("../../common/common-admin-links.ejs")%>

        <!-- Company common links -->

        <!-- Common scripts -->
        <%-include("../../common/common-scripts.ejs")%>

        <!-- Admin common scripts -->

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <%- include("../../common/common-admin-scripts.ejs")%>
    </head>
    <body>
        <%- include("../../components/navs/admin-navbar.ejs")%>

        <main>
            <section class="page-heading">
                <h2
                    class="text-center text-3xl font-extrabold text-gray-800 tracking-wide relative">
                    Dashboard
                    <span class="block h-1 w-16 bg-blue-500 mx-auto mt-2 rounded-full"></span>
                </h2>
            </section>

            <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <!-- href="/users" -->
                <a class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-blue-600">
                    <h5 class="text-lg font-medium text-gray-700">Total Users</h5>
                    <p id="totalUsers" class="text-4xl font-bold text-blue-800 mt-2">
                        <%= totalUsers %>
                    </p>
                </a>

                <a
                    href="/farmers"
                    class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-green-600">
                    <h5 class="text-lg font-medium text-gray-700">Total Farmers</h5>
                    <p id="totalFarmers" class="text-4xl font-bold text-green-800 mt-2">
                        <%= totalFarmers %>
                    </p>
                </a>

                <!-- href="/products" -->
                <a class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-orange-600">
                    <h5 class="text-lg font-medium text-gray-700">Total Products</h5>
                    <p id="totalProducts" class="text-4xl font-bold text-orange-800 mt-2">
                        <%= totalProducts %>
                    </p>
                </a>

                <div class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-purple-600">
                    <h5 class="text-lg font-medium text-gray-700">Product Categories</h5>
                    <p id="productCategoryCount" class="text-4xl font-bold text-purple-800 mt-2">
                        <%= Object.keys(JSON.parse(productsCategoryWiseCount)).length %>
                    </p>
                </div>
            </section>

            <!-- Chart  -->
            <section class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                <div class="bg-white p-5 rounded-lg shadow-md">
                    <h2 class="text-2xl font-bold mb-4">Product Range</h2>
                    <canvas id="productRangeChart" style="max-height: 300px"></canvas>
                </div>
            </section>
        </main>
    </body>

    <script>
                const productsCategoryWiseCount = <%- productsCategoryWiseCount %>; // Safe JSON output for chart

                          // Product Range Chart
                const productRangeCtx = document.getElementById('productRangeChart').getContext('2d');

                new Chart(productRangeCtx, {
            type: 'doughnut',
            data: {
                labels: productsCategoryWiseCount.map(pro => pro.category),
                datasets: [{
                    label: 'Product Range',
                    data: productsCategoryWiseCount.map(pro => pro.total_category_stock),
                    backgroundColor: ['#22c55e', '#facc15', '#f97316', '#3b82f6', '#8b5cf6'],
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: function(tooltipItem) {
                                const value = tooltipItem.raw;
                                const label = tooltipItem.label || '';
                                return `${label}: ${value} products`;
                            }
                        }
                    }
                }
            }
        });
    </script>
</html>
