<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <%- include("../../common/common-links.ejs") %> <%-
        include("../../common/common-user-links.ejs") %> <%-
        include("../../common/common-scripts.ejs") %>

        <script
            src="/javascripts/handlers/donations/add-donation-handler.js"
            type="module"
            defer></script>
    </head>

    <body class="bg-green-50 text-gray-800">
        <!-- Navbar -->
        <%- include("../../components/navs/user-navbar.ejs") %>

        <main
            class="max-w-4xl mx-auto mt-12 px-6 py-8 bg-white shadow-lg rounded-xl border border-green-300">
            <h1 class="text-3xl font-bold text-center text-green-700 mb-6">
                Donate Food to Help Others
            </h1>

            <form id="submit-donation-form" class="space-y-6">
                <!-- Food Category Selection -->
                <div>
                    <label for="food_category" class="block text-lg font-medium text-green-800">
                        Type of Food You Are Donating
                    </label>
                    <select
                        id="food_category"
                        name="food_category_id"
                        required
                        class="w-full mt-2 p-3 border border-green-400 rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none bg-green-50">
                        <option value="" selected>-- Select --</option>
                        <% foodCategories.forEach(category => { %>
                        <option value="<%= category.food_category_id %>">
                            <%= category.food_category_name %>
                        </option>
                        <% }) %>
                    </select>
                </div>

                <!-- Quantity Input -->
                <div>
                    <label for="quantity" class="block text-lg font-medium text-green-800">
                        Quantity Available (in kg)
                    </label>
                    <input
                        type="number"
                        id="quantity"
                        name="quantity"
                        min="1"
                        required
                        value="1"
                        class="w-full mt-2 p-3 border border-green-400 rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none bg-green-50" />
                </div>

                <!-- Expiry Date Input -->
                <div>
                    <label for="expiry_date" class="block text-lg font-medium text-green-800">
                        Best Before Date
                    </label>
                    <input
                        type="date"
                        id="expiry_date"
                        name="expiry_date"
                        required
                        class="w-full mt-2 p-3 border border-green-400 rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none bg-green-50" />
                </div>

                <!-- Pickup Address Input -->
                <div>
                    <label for="pickup_address" class="block text-lg font-medium text-green-800">
                        Pickup Address
                    </label>
                    <textarea
                        id="pickup_address"
                        name="pickup_address"
                        required
                        class="w-full mt-2 p-3 border border-green-400 rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none bg-green-50"
                        rows="3">
<%= user.address %></textarea
                    >
                </div>

                <!-- Hidden Input for Donor ID -->
                <input type="hidden" name="donor_id" value="<%= user.id %>" />

                <!-- Submit Button -->
                <div class="text-center">
                    <button
                        type="submit"
                        id="submit-donation-btn"
                        class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-lg text-lg transition duration-300 shadow-md">
                        Confirm Donation
                    </button>
                </div>
            </form>
        </main>

        <!-- Footer -->
        <footer class="bg-green-900 text-white text-center py-6 mt-12">
            <p class="text-lg">&copy; 2025 Waste Food Management. All Rights Reserved.</p>
        </footer>
    </body>
</html>
