<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <%- include("../../common/common-links.ejs") %> <%-
        include("../../common/common-user-links.ejs") %> <%-
        include("../../common/common-scripts.ejs") %>
    </head>

    <body class="bg-gray-100 text-gray-800">
        <!-- Navbar -->
        <%- include("../../components/navs/user-navbar.ejs") %>

        <main class="max-w-7xl mx-auto mt-10 px-4">
            <h1 class="text-4xl font-bold text-center text-gray-900 mb-8">
                My Requests (Total: <%= requests.length %>)
            </h1>

            <% if (requests.length === 0) { %>
            <p class="text-center text-gray-600 text-lg">No requests found.</p>
            <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% requests.forEach(request => { %>
                <div
                    class="bg-white shadow-lg rounded-xl p-6 border border-gray-200 transition transform hover:scale-105 hover:shadow-2xl">
                    <h2 class="text-2xl font-semibold text-gray-800 mb-2">
                        <%= request.food_category %>
                    </h2>
                    <p class="text-gray-700 text-lg">
                        <strong>Quantity:</strong> <%= request.donation_quantity %>
                    </p>
                    <p class="text-gray-700 text-lg">
                        <strong>Request Date:</strong> <%= request._createdAt %>
                    </p>
                    <p class="text-gray-700 text-lg">
                        <strong>Status:</strong>
                        <span
                            class="<%= request.status === 'pending' ? 'text-yellow-600 font-bold' : request.status === 'rejected' ? 'text-red-600 font-bold' : 'text-green-600 font-bold' %>">
                            <%= request.status.charAt(0).toUpperCase() + request.status.slice(1) %>
                        </span>
                    </p>
                </div>
                <% }); %>
            </div>
            <% } %>
        </main>

        <!-- Footer -->
        <footer class="bg-gray-900 text-white text-center py-6 mt-12">
            <p class="text-lg">&copy; 2025 Waste Food Management. All Rights Reserved.</p>
        </footer>
    </body>
</html>
