<!-- This is just for referecne, copy this layout for company pages -->

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%>

        <!-- Admin common links -->
        <%- include("../../common/common-admin-links.ejs")%>

        <!-- Company common links -->

        <!-- Common scripts -->
        <%-include("../../common/common-scripts.ejs")%>

        <!-- Admin common scripts -->

        <%- include("../../common/common-admin-scripts.ejs")%>

        <script
            src="/javascripts/handlers/farmers/farmerSignupHandler.js"
            type="module"
            defer></script>
    </head>
    <body>
        <% if (admin != null && admin !== undefined) { %> <%-
        include("../../components/navs/admin-navbar.ejs") %> <% } %>

        <main>
            <section class="page-heading">
                <h2
                    class="text-center text-3xl font-extrabold text-gray-800 tracking-wide relative">
                    <% if (admin != null && admin !== undefined) { %> Add Farmer<% }else { %> Signup
                    Farmer <% }%>
                    <span class="block h-1 w-16 bg-blue-500 mx-auto mt-2 rounded-full"></span>
                </h2>
            </section>

            <section class="p-4 flex justify-center items-center">
                <div class="w-1/2">
                    <form id="farmer-signup-form" class="space-y-6">
                        <!-- Full Name -->
                        <div>
                            <label for="farmer_name" class="block text-gray-700 font-medium mb-1"
                                >Full Name</label
                            >
                            <input
                                type="text"
                                id="farmer_name"
                                name="farmer_name"
                                class="w-full border border-gray-300 px-4 py-2 rounded"
                                placeholder="Your full name"
                                required />
                        </div>

                        <!-- Email Address -->
                        <div>
                            <label for="email" class="block text-gray-700 font-medium mb-1"
                                >Email Address</label
                            >
                            <input
                                type="email"
                                id="email"
                                name="email"
                                class="w-full border border-gray-300 px-4 py-2 rounded"
                                placeholder="Your email address"
                                required />
                        </div>

                        <!-- Password -->
                        <div>
                            <label for="password" class="block text-gray-700 font-medium mb-1"
                                >Password</label
                            >
                            <input
                                type="password"
                                id="password"
                                name="password"
                                class="w-full border border-gray-300 px-4 py-2 rounded"
                                placeholder="Enter your password"
                                required />
                        </div>

                        <!-- Contact Number -->
                        <div>
                            <label for="contact_number" class="block text-gray-700 font-medium mb-1"
                                >Contact Number</label
                            >
                            <input
                                type="tel"
                                id="mobile"
                                ,
                                name="mobile"
                                ,
                                maxlength="10"
                                class="w-full border border-gray-300 px-4 py-2 rounded"
                                placeholder="Your contact number" />
                        </div>

                        <!-- Address -->
                        <div>
                            <label for="address" class="block text-gray-700 font-medium mb-1"
                                >Address</label
                            >
                            <textarea
                                id="address"
                                name="address"
                                class="w-full border border-gray-300 px-4 py-2 rounded"
                                placeholder="Your residential address"></textarea>
                        </div>

                        <!-- Farm Name -->
                        <div>
                            <label for="farm_name" class="block text-gray-700 font-medium mb-1"
                                >Farm Name</label
                            >
                            <input
                                type="text"
                                id="farm_name"
                                name="farm_name"
                                class="w-full border border-gray-300 px-4 py-2 rounded"
                                placeholder="Name of your farm"
                                required />
                        </div>

                        <!-- Farm Location -->
                        <div>
                            <label for="farm_location" class="block text-gray-700 font-medium mb-1"
                                >Farm Location</label
                            >
                            <input
                                type="text"
                                id="farm_location"
                                name="farm_location"
                                class="w-full border border-gray-300 px-4 py-2 rounded"
                                placeholder="Location of your farm" />
                        </div>

                        <!-- Established Year -->
                        <div>
                            <label
                                for="established_year"
                                class="block text-gray-700 font-medium mb-1"
                                >Established Year</label
                            >
                            <input
                                type="number"
                                id="established_year"
                                name="established_year"
                                class="w-full border border-gray-300 px-4 py-2 rounded"
                                placeholder="Year your farm was established" />
                        </div>

                        <!-- Farm Size -->
                        <div>
                            <label for="farm_size" class="block text-gray-700 font-medium mb-1"
                                >Farm Size (in acres)</label
                            >
                            <input
                                type="number"
                                step="0.1"
                                id="farm_size"
                                name="farm_size"
                                class="w-full border border-gray-300 px-4 py-2 rounded"
                                placeholder="Size of your farm in acres" />
                        </div>

                        <!-- Submit Button -->
                        <button
                            type="submit"
                            id="farmer-signup-btn"
                            class="w-full py-2 px-4 bg-emerald-600 text-white rounded hover:bg-emerald-800 transition duration-300">
                            <% if (admin != null && admin !== undefined) { %> Add<% }else { %>
                            Signup <% }%>
                        </button>
                    </form>
                </div>
            </section>
        </main>
    </body>
</html>
