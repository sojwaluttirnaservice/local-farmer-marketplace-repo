<!-- This is just for referecne, copy this layout for company pages -->

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%>

        <!-- Admin common links -->
        <%- include("../../common/common-admin-links.ejs")%>

        <!-- Company common links -->

        <!-- Common scripts -->
        <%-include("../../common/common-scripts.ejs")%>

        <!-- Admin common scripts -->

        <%- include("../../common/common-admin-scripts.ejs")%>

        <script
            src="/javascripts/handlers/farmers/farmerSignupHandler.js"
            type="module"
            defer></script>
    </head>
    <body>
        <%- include("../../components/navs/admin-navbar.ejs") %>

        <main>
           

            <section
                data-role="www"
                class="flex items-center justify-between py-4 px-6 bg-white shadow-md rounded-md">
                <!-- 🔙 Back Button -->
                <button
                    onclick="window.history.back()"
                    class="flex items-center text-gray-700 hover:text-blue-600 font-semibold transition duration-300">
                    <i class="fas fa-arrow-left mr-2"></i> Back
                </button>

                <!-- 📌 Page Title -->
                <h2
                    class="text-3xl font-extrabold text-gray-800 tracking-wide relative text-center flex-grow">
                    Farmers List (
                    <span class="italic"> Total Farmers : </span>
                    <% if (typeof farmersList !== 'undefined' && farmersList !== null &&
                    farmersList.length > 0) { %> <%= farmersList.length %> <% } else { %> 0 <% } %>)
                </h2>

                <!-- Placeholder for Alignment (Keeps title centered) -->
                <div class="w-20"></div>
            </section>

            <section class="p-6 bg-white shadow-md rounded-lg">
                <h2 class="text-2xl font-bold mb-4 text-center text-gray-900">Farmers List</h2>
            
                <div class="overflow-x-auto">
                    <% if (farmersList && farmersList.length > 0) { %>
                        <table class="min-w-full bg-white border border-gray-200 shadow-md rounded-lg">
                            <!-- Table Head -->
                            <thead class="bg-green-600 text-white">
                                <tr>
                                    <th class="px-4 py-3 text-left text-sm font-medium">#</th>
                                    <th class="px-4 py-3 text-left text-sm font-medium">Farmer Name</th>
                                    <th class="px-4 py-3 text-left text-sm font-medium">Email</th>
                                    <th class="px-4 py-3 text-left text-sm font-medium">Mobile</th>
                                    <th class="px-4 py-3 text-left text-sm font-medium">Address</th>
                                    <th class="px-4 py-3 text-left text-sm font-medium">Farm Name</th>
                                    <th class="px-4 py-3 text-left text-sm font-medium">Established Year</th>
                                    <th class="px-4 py-3 text-left text-sm font-medium">Farm Size (Acres)</th>
                                    <th class="px-4 py-3 text-left text-sm font-medium">Products Sold</th>
                                    <th class="px-4 py-3 text-left text-sm font-medium">Add Product</th>
                                </tr>
                            </thead>
            
                            <!-- Table Body -->
                            <tbody class="divide-y divide-gray-200 bg-gray-50">
                                <% farmersList.forEach((farmer, index) => { %>
                                    <tr class="hover:bg-green-100 transition duration-200">
                                        <!-- Serial Number -->
                                        <td class="px-4 py-3 text-sm text-gray-700"><%= index + 1 %></td>
            
                                        <!-- Farmer Name -->
                                        <td class="px-4 py-3 text-sm text-gray-900 font-medium"><%= farmer.farmer_name %></td>
            
                                        <!-- Email -->
                                        <td class="px-4 py-3 text-sm text-gray-700"><%= farmer.email %></td>
            
                                        <!-- Mobile -->
                                        <td class="px-4 py-3 text-sm text-gray-700"><%= farmer.mobile || 'N/A' %></td>
            
                                        <!-- Address -->
                                        <td class="px-4 py-3 text-sm text-gray-700"><%= farmer.address || 'N/A' %></td>
            
                                        <!-- Farm Name -->
                                        <td class="px-4 py-3 text-sm text-gray-700"><%= farmer.farm_name %></td>
            
                                        <!-- Established Year -->
                                        <td class="px-4 py-3 text-sm text-gray-700"><%= farmer.established_year || 'N/A' %></td>
            
                                        <!-- Farm Size -->
                                        <td class="px-4 py-3 text-sm text-gray-700"><%= farmer.farm_size || 'N/A' %></td>
            
                                        <!-- Products Sold -->
                                        <td class="px-4 py-3 text-sm font-semibold text-gray-700"><%= farmer.products_sold || 0 %></td>
            
                                        <!-- Add Product Button -->
                                        <td class="px-4 py-3 text-sm">
                                            <a href="/sales/add/<%= farmer.id %>"
                                                class="px-4 py-2 bg-green-600 text-white font-semibold rounded-lg shadow-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition duration-300">
                                                <i class="fa-solid fa-plus"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <!-- No Data Message -->
                        <div class="py-4 px-6 text-center bg-red-100 border border-red-300 text-red-700 font-semibold rounded-lg">
                            No farmer is listed
                        </div>
                    <% } %>
                </div>
            </section>
            
        </main>
    </body>
</html>
