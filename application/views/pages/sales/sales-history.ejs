<!-- This is just for referecne, copy this layout for company pages -->

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%>

        <!-- Admin common links -->
        <%- include("../../common/common-admin-links.ejs")%>

        <!-- Company common links -->

        <!-- Common scripts -->
        <%-include("../../common/common-scripts.ejs")%>

        <!-- Admin common scripts -->

        <%- include("../../common/common-admin-scripts.ejs")%>

        <script src="/javascripts/handlers/sales/addSaleHandler.js" type="module" defer></script>
    </head>
    <body>
        <%- include("../../components/navs/admin-navbar.ejs")%>

        <main>
            <section class="page-heading">
                <h2
                    class="text-center text-3xl font-extrabold text-gray-800 tracking-wide relative">
                   Sales History
                    <!--  (<span class="italic"> Total Farmers : </span>
                    <% if (typeof farmersList !== 'undefined' && farmersList !== null &&
                    farmersList.length > 0) { %> <%= farmersList.length %> <% } else { %> 0 <% } %>) -->
                    <span class="block h-1 w-16 bg-blue-500 mx-auto mt-2 rounded-full"></span>
                </h2>
            </section>

            <section class="p-4">
                <button
                    onclick="history.back()"
                    class="bg-teal-700 hover:bg-teal-800 text-white font-bold py-2 px-4 rounded-lg shadow-md transition duration-300 ease-in-out">
                    ← Back
                </button>
            </section>

            <section>
                <h2 class="block text-gray-700 text-2xl font-bold mb-6 text-center">
                    Farmer Details
                </h2>
                <form
                    class="w-full max-w-lg bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4 mx-auto">
                    <div class="flex justify-between items-center space-x-4">
                        <!-- Farmer Name -->
                        <div class="w-1/3">
                            <label class="block text-gray-700 text-sm font-bold mb-2">
                                Name:
                            </label>
                            <p class="text-gray-900"><%= farmer.farmer_name %></p>
                        </div>

                        <!-- Products Sold -->
                        <div class="w-1/3">
                            <label class="block text-gray-700 text-sm font-bold mb-2">
                                Products Sold:
                            </label>
                            <p class="text-gray-900"><%= farmer.products_sold %></p>
                        </div>

                        <!-- History Button -->
                        <div class="w-1/3">
                            <label class="block text-gray-700 text-sm font-bold mb-2">
                                History:
                            </label>
                            <a
                                href="/sales/history/<%= farmer.id %>"
                                class="text-blue-600 underline hover:text-blue-800 font-bold transition duration-300">
                                History
                            </a>
                        </div>
                    </div>
                </form>
            </section>

            <section class="section farmers-sales-history-section p-4">
                <div class="container mx-auto">
                    <h2 class="text-3xl font-bold text-center mb-8">Sales History</h2>
                    <div class="overflow-x-auto shadow-lg rounded-lg">
                        <table class="min-w-full bg-white divide-y divide-gray-200">
                            <thead class="bg-teal-700">
                                <tr>
                                    <th
                                        class="py-3 px-6 text-left text-sm font-medium text-white uppercase tracking-wider">
                                        Sale Date
                                    </th>
                                    <th
                                        class="py-3 px-6 text-left text-sm font-medium text-white uppercase tracking-wider">
                                        Product Name
                                    </th>
                                    <th
                                        class="py-3 px-6 text-left text-sm font-medium text-white uppercase tracking-wider">
                                        Category
                                    </th>
                                    <th
                                        class="py-3 px-6 text-left text-sm font-medium text-white uppercase tracking-wider">
                                        Stock Sold
                                    </th>
                                    <th
                                        class="py-3 px-6 text-left text-sm font-medium text-white uppercase tracking-wider">
                                        Price per Unit
                                    </th>
                                    <th
                                        class="py-3 px-6 text-left text-sm font-medium text-white uppercase tracking-wider">
                                        Sale Amount
                                    </th>
                                    <th
                                        class="py-3 px-6 text-left text-sm font-medium text-white uppercase tracking-wider">
                                        Payment Status
                                    </th>
                                    <th
                                        class="py-3 px-6 text-left text-sm font-medium text-white uppercase tracking-wider">
                                        Payment Method
                                    </th>
                                    <th
                                        class="py-3 px-6 text-left text-sm font-medium text-white uppercase tracking-wider">
                                        Transaction ID
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% if (farmerSalesHistory && farmerSalesHistory.length > 0) { %> <%
                                farmerSalesHistory.forEach(sale => { %>
                                <tr class="hover:bg-gray-50">
                                    <td class="py-3 px-6 text-sm text-gray-700">
                                        <%= sale._sale_date%>
                                    </td>
                                    <td class="py-3 px-6 text-sm text-gray-700">
                                        <%= sale.product_name %>
                                    </td>
                                    <td class="py-3 px-6 text-sm text-gray-700">
                                        <%= sale.category %>
                                    </td>
                                    <td class="py-3 px-6 text-sm text-gray-700">
                                        <%= sale.stock_quantity %>
                                    </td>
                                    <td class="py-3 px-6 text-sm text-gray-700">
                                        <%= sale.price_per_unit_at_transaction %>
                                    </td>
                                    <td class="py-3 px-6 text-sm text-gray-700">
                                        <%= sale.sale_amount %>
                                    </td>
                                    <td class="py-3 px-6 text-sm text-gray-700">
                                        <%= sale.payment_status %>
                                    </td>
                                    <td class="py-3 px-6 text-sm text-gray-700">
                                        <%= sale.payment_method || '-' %>
                                    </td>
                                    <td class="py-3 px-6 text-sm text-gray-700">
                                        <%= sale.transaction_id || '-' %>
                                    </td>
                                </tr>
                                <% }); %> <% } else { %>
                                <tr>
                                    <td colspan="9" class="text-center py-6 text-gray-500">
                                        No sales history found.
                                    </td>
                                </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </body>
</html>
