<!-- This is just for referecne, copy this layout for company pages -->

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%>

        <!-- Admin common links -->
        <%- include("../../common/common-admin-links.ejs")%>

        <!-- Company common links -->

        <!-- Common scripts -->
        <%-include("../../common/common-scripts.ejs")%>

        <!-- Admin common scripts -->

        <%- include("../../common/common-admin-scripts.ejs")%>

        <script src="/javascripts/handlers/sales/addSaleHandler.js" type="module" defer></script>
    </head>
    <body>
        <%- include("../../components/navs/admin-navbar.ejs")%>

        <main>
            <section class="page-heading">
                <h2
                    class="text-center text-3xl font-extrabold text-gray-800 tracking-wide relative">
                    Add Sale 
                    <span class="block h-1 w-16 bg-blue-500 mx-auto mt-2 rounded-full"></span>
                </h2>
            </section>

            <section class="p-4">
                <button
                    onclick="history.back()"
                    class="bg-teal-700 hover:bg-teal-800 text-white font-bold py-2 px-4 rounded-lg shadow-md transition duration-300 ease-in-out">
                    ← Back
                </button>
            </section>

            <section>
                <h2 class="block text-gray-700 text-2xl font-bold mb-6 text-center">
                    Farmer Details
                </h2>
                <form class="w-full max-w-lg bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4 mx-auto">
                    <div class="flex justify-between items-center space-x-4">
                        <!-- Farmer Name -->
                        <div class="w-1/3">
                            <label class="block text-gray-700 text-sm font-bold mb-2">
                                Name:
                            </label>
                            <p class="text-gray-900"><%= farmer.farmer_name %></p>
                        </div>
            
                        <!-- Products Sold -->
                        <div class="w-1/3">
                            <label class="block text-gray-700 text-sm font-bold mb-2">
                                Products Sold:
                            </label>
                            <p class="text-gray-900"><%= farmer.products_sold %></p>
                        </div>
            
                        <!-- History Button -->
                        <div class="w-1/3">
                            <label class="block text-gray-700 text-sm font-bold mb-2">
                                History:
                            </label>
                            <a href="/sales/history/<%= farmer.id %>" 
                                class="text-blue-600 underline hover:text-blue-800 font-bold transition duration-300">
                                 History
                             </a>
                             
                        </div>
                    </div>
                </form>
            </section>
            

            <section class="px-4 flex justify-center items-center">
                <form
                    id="add-sale-form"
                    class="w-full max-w-lg bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4">
                    <h2 class="block text-gray-700 text-2xl font-bold mb-6 text-center">
                        Add Sale Record
                    </h2>

                    <!-- Hidden Farmer ID -->
                    <input type="hidden" name="farmer_id_fk" value="<%= farmer.id %>" />

                    <!-- Product Dropdown -->
                    <div class="mb-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div class="">
                                <label
                                    class="block text-gray-700 text-sm font-bold mb-2"
                                    for="predefined_product_id_fk">
                                    Select Product
                                </label>
                                <select
                                    id="predefined_product_id_fk"
                                    name="predefined_product_id_fk"
                                    required
                                    class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2">
                                    <option value="">-- Select a Product --</option>
                                    <% predefinedProductsList.forEach(product => { %>
                                    <option
                                        value="<%= product.id %>"
                                        data-pricePerUnit="<%= product.price_per_unit%>"
                                        data-unitOfMeasurement="<%= product.unit_of_measurement %>">
                                        <%= product.product_name %>
                                    </option>
                                    <% }); %>
                                </select>
                            </div>

                            <div>
                                <label
                                    class="block text-gray-700 text-sm font-bold mb-2"
                                    for="unit_of_measurement">
                                    Unit
                                </label>
                                <input
                                    type="text"
                                    id="unit_of_measurement"
                                    name="unit_of_measurement"
                                    value=""
                                    readonly
                                    class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2" />
                            </div>
                        </div>
                    </div>

                    <!-- Stock Quantity -->
                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="stock_quantity">
                            Quantity Sold
                        </label>
                        <input
                            type="number"
                            id="stock_quantity"
                            name="stock_quantity"
                            step="1"
                            required
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2" />
                    </div>

                    <!-- Price per Unit -->
                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="price_per_unit_at_transaction">
                            Price per Unit
                        </label>
                        <input
                            type="number"
                            id="price_per_unit_at_transaction"
                            name="price_per_unit_at_transaction"
                            step="0.01"
                            required
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2" />
                    </div>

                    <!-- Sale Amount (auto-calculated) -->
                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="sale_amount">
                            Sale Amount
                        </label>
                        <input
                            type="number"
                            id="sale_amount"
                            name="sale_amount"
                            readonly
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-gray-100 text-gray-900 placeholder-gray-400 outline-none focus:ring-2" />
                    </div>

                    <!-- Sale Date -->
                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="sale_date">
                            Sale Date
                        </label>
                        <input
                            type="date"
                            id="sale_date"
                            name="sale_date"
                            required
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2" />
                    </div>

                    <!-- Payment Method -->
                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="payment_method">
                            Payment Method (Optional)
                        </label>
                        <select
                            id="payment_method"
                            name="payment_method"
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2">
                            <option value="">-- Select Payment Method --</option>
                            <option value="Bank Transfer">Bank Transfer</option>
                            <option value="Cash">Cash</option>
                            <option value="Online Payment">Online Payment</option>
                        </select>
                    </div>

                    <!-- Payment Status -->
                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="payment_status">
                            Payment Status
                        </label>
                        <select
                            id="payment_status"
                            name="payment_status"
                            required
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2">
                            <option value="Pending">Pending</option>
                            <option value="Completed">Completed</option>
                            <option value="Failed">Failed</option>
                        </select>
                    </div>

                    <!-- Transaction ID -->
                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            for="transaction_id">
                            Transaction ID (Optional)
                        </label>
                        <input
                            type="text"
                            id="transaction_id"
                            name="transaction_id"
                            class="focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-md border border-gray-300 p-2 bg-white text-gray-900 placeholder-gray-400 outline-none focus:ring-2" />
                    </div>

                    <!-- Submit Button -->
                    <div class="flex items-center justify-center">
                        <button
                            type="submit"
                            id="add-sale-btn"
                            class="bg-teal-700 hover:bg-teal-800 text-white font-bold py-2 px-6 rounded focus:outline-none focus:shadow-outline">
                            Add Sale
                        </button>
                    </div>
                </form>
            </section>
        </main>
    </body>
</html>
