<!-- This is just for referecne, copy this layout for company pages -->

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%>

        <!-- Admin common links -->
        <% if(typeof user !== 'undefined' && typeof user != null) {%>
        <%-include("../../common/common-user-links.ejs")%> <% } else {%>
        <%-include("../../common/common-admin-links.ejs")%> <% } %>

        <!-- Company common links -->

        <!-- Common scripts -->
        <%-include("../../common/common-scripts.ejs")%>

        <!-- Admin common scripts -->

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <% if(typeof user !== 'undefined' && typeof user != null) {%> <%-
        include("../../common/common-user-scripts.ejs")%> <% } else {%> <%-
        include("../../common/common-admin-scripts.ejs")%> <% } %>
    </head>
    <body>
        <% if(typeof user !== 'undefined' && typeof user != null) {%>
        <%-include("../../components/navs/user-navbar.ejs")%> <% } else {%>
        <%-include("../../components/navs/admin-navbar.ejs")%> <% } %>

        <main>
            <% if(typeof user !== 'undefined' && typeof user != null) {%>
            
            <!--  -->
            <% } else {%>
            <!--  -->
            <section
            data-role="page-heading"
            class="flex items-center justify-between py-4 px-6 bg-white shadow-md rounded-md">
            <!-- 🔙 Back Button -->
            <button
                onclick="window.history.back()"
                class="flex items-center text-gray-700 hover:text-blue-600 font-semibold transition duration-300">
                <i class="fas fa-arrow-left mr-2"></i> Back
            </button>

            <!-- 📌 Page Title -->
            <h2
                class="text-3xl font-extrabold text-gray-800 tracking-wide relative text-center flex-grow">
                Orders
                <span class="block h-1 w-16 bg-blue-500 mx-auto mt-2 rounded-full"></span>
            </h2>

            <!-- Placeholder for Alignment (Keeps title centered) -->
            <div class="w-20"></div>
        </section>
            <!--  -->
            <% } %>

           

            <section class="py-10 px-6 bg-gray-100 min-h-screen">
                <div class="container mx-auto max-w-5xl bg-white shadow-lg rounded-lg p-8">
                    <!-- 📝 Order Summary -->
                    <div class="border-b pb-6 mb-6">
                        <h2 class="text-3xl font-bold text-gray-900 flex items-center">
                            <i class="fas fa-receipt text-green-600 mr-3"></i> Order Summary
                        </h2>

                        <% if (orderDetails) { %>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mt-4 text-gray-700">
                            <div>
                                <p>
                                    <i class="fas fa-hashtag text-gray-500 mr-2"></i>
                                    <strong>Order ID:</strong> <%= orderDetails.order_id || 'N/A' %>
                                </p>
                                <p>
                                    <i class="fas fa-user text-gray-500 mr-2"></i>
                                    <strong>User:</strong> <%= user.name %>
                                </p>
                              
                            </div>
                            <div>
                                <p>
                                    <i class="fas fa-calendar-alt text-gray-500 mr-2"></i>
                                    <strong>Order Date:</strong> <%= orderDetails.order_date ||
                                    'N/A' %>
                                </p>
                                <p>
                                    <i class="fas fa-clock text-gray-500 mr-2"></i>
                                    <strong>Last Updated:</strong> <%= orderDetails.last_updated ||
                                    'N/A' %>
                                </p>
                            </div>
                            <div class="text-xl font-semibold text-gray-800">
                                <p>
                                    <i class="fas fa-money-bill-wave text-green-500 mr-2"></i>
                                    <strong>Total Amount:</strong> ₹<%= orderDetails.total_amount ||
                                    '0.00' %>
                                </p>
                            </div>
                        </div>
                        <% } else { %>
                        <!-- ❌ Order Not Found -->
                        <div
                            class="text-center text-red-500 font-semibold bg-red-100 p-4 rounded-lg border border-red-300 mt-4">
                            <i class="fas fa-exclamation-circle mr-2"></i> Order details not
                            available.
                        </div>
                        <% } %>
                    </div>

                    <!-- ✅ Payment & Delivery Status -->
                    <% if (orderDetails) { %>
                    <div
                        class="bg-gray-50 p-6 rounded-lg shadow-md flex flex-col md:flex-row justify-between items-center mb-6">
                        <div class="text-center md:text-left">
                            <p class="text-lg font-semibold text-gray-700">
                                <i class="fas fa-check-circle text-gray-500 mr-2"></i> Payment
                                Status:
                                <span
                                    class="px-4 py-1 rounded-full text-white font-bold <%= orderDetails.payment_status === 'Completed' ? 'bg-green-500' : 'bg-red-500' %>">
                                    <%= orderDetails.payment_status || 'Unknown' %>
                                </span>
                            </p>
                            <p class="text-sm text-gray-600">
                                <i class="fas fa-barcode text-gray-500 mr-2"></i>
                                <strong>Payment ID:</strong> <%=
                                orderDetails.razorpay_payment_id || 'N/A' %>
                            </p>
                            <p class="text-sm text-gray-600">
                                <i class="fas fa-barcode text-gray-500 mr-2"></i>
                                <strong>Payment order ID:</strong> <%=
                                orderDetails.razorpay_order_id || 'N/A' %>
                            </p>
                        </div>
                        <div class="text-center md:text-left">
                            <p class="text-lg font-semibold text-gray-700">
                                <i class="fas fa-shipping-fast text-gray-500 mr-2"></i> Delivery
                                Status:
                                <span
                                    class="px-4 py-1 rounded-full text-white font-bold <%= orderDetails.delivery_status === 'Delivered' ? 'bg-blue-500' : 'bg-orange-500' %>">
                                    <%= orderDetails.delivery_status || 'Unknown' %>
                                </span>
                            </p>
                        </div>
                    </div>
                    <% } %>

                    <!-- 🛒 Ordered Products -->
                    <% if (orderDetails && orderDetails.ordered_items &&
                    orderDetails.ordered_items.length > 0) { %>
                    <div class="mt-6">
                        <h3 class="text-2xl font-semibold text-gray-800 mb-4 flex items-center">
                            <i class="fas fa-box text-teal-700 mr-3"></i> Ordered Items
                        </h3>
                        <div class="overflow-x-auto">
                            <table
                                class="w-full bg-white border border-gray-200 shadow-md rounded-lg">
                                <thead class="bg-green-600 text-white">
                                    <tr>
                                        <th class="px-4 py-3 text-left text-sm font-medium">#</th>
                                        <th class="px-4 py-3 text-left text-sm font-medium">
                                            Product Name
                                        </th>
                                        <th class="px-4 py-3 text-left text-sm font-medium">
                                            Category
                                        </th>
                                        <th class="px-4 py-3 text-left text-sm font-medium">
                                            Quantity
                                        </th>
                                        <th class="px-4 py-3 text-left text-sm font-medium">
                                            Price/Unit
                                        </th>
                                        <th class="px-4 py-3 text-left text-sm font-medium">
                                            Subtotal
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-200 bg-gray-50">
                                    <% orderDetails.ordered_items.forEach((item, index) => { %>
                                    <tr class="hover:bg-green-100 transition duration-200">
                                        <td class="px-4 py-3 text-sm text-gray-700">
                                            <%= index + 1 %>
                                        </td>
                                        <td
                                            class="px-4 py-3 text-sm text-gray-900 font-medium flex items-center">
                                            <i class="fas fa-cube text-green-500 mr-2"></i> <%=
                                            item.product_name || 'N/A' %>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-gray-700">
                                            <%= item.category || 'N/A' %>
                                        </td>
                                        <td class="px-4 py-3 text-sm font-semibold text-gray-700">
                                            <%= item.quantity || 0 %>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-gray-700">
                                            ₹<%= item.price_at_order_time || '0.00' %>
                                        </td>
                                        <td class="px-4 py-3 text-sm font-bold text-gray-900">
                                            ₹<%= item.total_price || '0.00' %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <% } else { %>
                    <!-- ❌ No Products Found -->
                    <p
                        class="text-center text-red-500 font-semibold bg-red-100 p-4 rounded-lg border border-red-300 mt-4">
                        <i class="fas fa-exclamation-circle mr-2"></i> No ordered items found.
                    </p>
                    <% } %>

                    <!-- 🔙 Back Button -->
                    <div class="mt-8 flex justify-end">
                        <a
                            hidden
                            href="/orders"
                            class="px-5 py-2 bg-gray-700 text-white text-sm font-semibold rounded-lg hover:bg-gray-900 transition duration-300 flex items-center shadow-md">
                            <i class="fas fa-arrow-left mr-2"></i> Back to Orders
                        </a>
                    </div>
                </div>
            </section>
        </main>
    </body>
</html>
