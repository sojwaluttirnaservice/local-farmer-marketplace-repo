<!-- This is just for referecne, copy this layout for company pages -->

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>

        <!-- Common links -->
        <%- include("../../common/common-links.ejs")%>

        <!-- Admin common links -->
        <% if(typeof user !== 'undefined' && typeof user != null) {%>
        <%-include("../../common/common-user-links.ejs")%> <% } else {%>
        <%-include("../../common/common-admin-links.ejs")%> <% } %> 

        <!-- Company common links -->

        <!-- Common scripts -->
        <%-include("../../common/common-scripts.ejs")%>

        <!-- Admin common scripts -->

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
         <!-- Admin common links -->
         <% if(typeof user !== 'undefined' && typeof user != null) {%>
            <%-include("../../common/common-user-scripts.ejs")%> <% } else {%>
            <%-include("../../common/common-admin-scripts.ejs")%> <% } %> 
    </head>
    <body>
        <% if(typeof user !== 'undefined' && typeof user != null) {%>

        <%-include("../../components/navs/user-navbar.ejs")%> <% } else {%>
        <%-include("../../components/navs/admin-navbar.ejs")%> <% } %> 

        <main>

             <!-- Admin common links -->
            <% if(typeof user !== 'undefined' && typeof user != null) {%>

              <!-- Show nothings lol -->
          
            <% } else {%>
                <section
                data-role="page-heading"
                class="flex items-center justify-between py-4 px-6 bg-white shadow-md rounded-md">
                <!-- 🔙 Back Button -->
                <button
                    onclick="window.history.back()"
                    class="flex items-center text-gray-700 hover:text-blue-600 font-semibold transition duration-300">
                    <i class="fas fa-arrow-left mr-2"></i> Back
                </button>
  
                <!-- 📌 Page Title -->
                <h2
                    class="text-3xl font-extrabold text-gray-800 tracking-wide relative text-center flex-grow">
                    Orders
                    <span class="block h-1 w-16 bg-blue-500 mx-auto mt-2 rounded-full"></span>
                </h2>
  
                <!-- Placeholder for Alignment (Keeps title centered) -->
                <div class="w-20"></div>
            </section>
            
            
            <!-- 🧑‍💼 User Details Section -->
            <section class="bg-white p-6 rounded-lg shadow-lg mb-6">
                <h2 class="text-2xl font-semibold text-gray-800 text-center mb-4">
                    <i class="fas fa-user-circle text-blue-600 mr-2"></i> User Information
                </h2>

                <% if (userDetails) { %>
                <div class="bg-gray-50 border border-gray-200 p-4 rounded-lg">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <!-- Name -->
                        <div class="flex items-center space-x-3">
                            <i class="fas fa-user text-gray-500"></i>
                            <span class="font-semibold text-gray-600">Name:</span>
                            <p class="text-gray-900 font-medium"><%= userDetails.name %></p>
                        </div>

                        <!-- Email -->
                        <div class="flex items-center space-x-3">
                            <i class="fas fa-envelope text-gray-500"></i>
                            <span class="font-semibold text-gray-600">Email:</span>
                            <p class="text-gray-900 font-medium"><%= userDetails.email %></p>
                        </div>

                        <!-- Mobile -->
                        <div class="flex items-center space-x-3">
                            <i class="fas fa-phone text-gray-500"></i>
                            <span class="font-semibold text-gray-600">Mobile:</span>
                            <p class="text-gray-900 font-medium"><%= userDetails.mobile || 'N/A' %></p>
                        </div>

                        <!-- Address -->
                        <div class="flex items-center space-x-3">
                            <i class="fas fa-map-marker-alt text-gray-500"></i>
                            <span class="font-semibold text-gray-600">Address:</span>
                            <p class="text-gray-900 font-medium"><%= userDetails.address || 'N/A' %></p>
                        </div>

                        <!-- Total Orders -->
                        <div class="flex items-center space-x-3">
                            <i class="fas fa-shopping-cart text-gray-500"></i>
                            <span class="font-semibold text-gray-600">Total Orders:</span>
                            <p class="text-gray-900 font-medium">
                                <%= orders?.total_orders || 0 %>
                            </p>
                        </div>
                    </div>
                </div>
                <% } else { %>
                <!-- ❌ User Not Found -->
                <div
                    class="text-center text-red-500 font-semibold bg-red-100 p-4 rounded-lg border border-red-300">
                    <i class="fas fa-exclamation-circle mr-2"></i> User information is not
                    available.
                </div>
                <% } %>
            </section>
            <% } %> 
            <!-- 📦 Orders List Section -->
            <section class="bg-white p-6 rounded-lg shadow-lg">
                <h2 class="text-2xl font-semibold text-gray-800 text-center mb-6">
                    <i class="fas fa-box text-green-600 mr-2"></i> Order History
                </h2>

                <% if (orders && orders.orders && orders.orders.length > 0) { %>
                <div class="overflow-x-auto">
                    <table class="min-w-full bg-white border border-gray-200 shadow-md rounded-lg">
                        <!-- Table Head -->
                        <thead class="bg-green-600 text-white">
                            <tr>
                                <th class="px-4 py-3 text-left text-sm font-medium">Order ID</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">
                                    Payment Status
                                </th>
                                <th class="px-4 py-3 text-left text-sm font-medium">
                                    Delivery Status
                                </th>
                                <th class="px-4 py-3 text-left text-sm font-medium">
                                    Payment Mode
                                </th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Created At</th>
                                <th class="px-4 py-3 text-left text-sm font-medium">Actions</th>
                            </tr>
                        </thead>

                        <!-- Table Body -->
                        <tbody class="divide-y divide-gray-200 bg-gray-50">
                            <% orders.orders.forEach((order) => { %>
                            <tr class="hover:bg-green-100 transition duration-300">
                                <td class="px-4 py-3 text-sm text-gray-700 font-medium">
                                    <%= order.id %>
                                </td>
                                <td class="px-4 py-3 text-sm font-semibold">
                                    <span
                                        class="px-2 py-1 rounded-md <% if (order.payment_status === 'Completed') { %> bg-green-500 text-white <% } else if (order.payment_status === 'Pending') { %> bg-yellow-500 text-white <% } else { %> bg-red-500 text-white <% } %>">
                                        <%= order.payment_status %>
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-sm font-semibold">
                                    <span
                                        class="px-2 py-1 rounded-md <% if (order.delivery_status === 'Delivered') { %> bg-blue-500 text-white <% } else if (order.delivery_status === 'Out for Delivery') { %> bg-orange-500 text-white <% } else { %> bg-gray-500 text-white <% } %>">
                                        <%= order.delivery_status %>
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-sm text-gray-700">
                                    <%= order.payment_mode %>
                                </td>
                                <td class="px-4 py-3 text-sm text-gray-600">
                                    <%= new Date(order.createdAt).toLocaleString('en-GB', { day:
                                    '2-digit', month: 'short', year: 'numeric', hour: '2-digit',
                                    minute: '2-digit', second: '2-digit' }) %>
                                </td>
                                <td class="px-4 py-3">
                                    <a
                                        href="/orders/o/<%= order.id %>"
                                        class="px-3 py-1 bg-blue-500 text-white text-xs rounded-md hover:bg-blue-600 transition">
                                        <i class="fas fa-eye mr-1"></i> View Details
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                <!-- ❌ No Orders Found -->
                <p
                    class="text-center text-red-500 font-semibold mt-4 bg-red-100 p-4 rounded-lg border border-red-300">
                    <i class="fas fa-exclamation-circle mr-2"></i> No orders found for this user.
                </p>
                <% } %>
            </section>
        </main>
    </body>
</html>
