<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Sign Up | Waste Food Management</title>

        <%- include("../../common/common-links.ejs")%> <%-
        include("../../common/common-scripts.ejs") %>
        <script src="/javascripts/handlers/auth/signupHandler.js" type="module" defer></script>

        <style>
            .background-container {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                z-index: -1;
            }
            .background-container img {
                width: 100%;
                object-fit: cover;
            }
            .background-overlay {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.5);
                z-index: -1;
            }
            .content-container {
                position: relative;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                z-index: 10;
            }
            .glassmorphism {
                background: rgba(255, 255, 255, 0.2);
                backdrop-filter: blur(15px);
                border-radius: 12px;
                padding: 30px;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
                border: 1px solid rgba(255, 255, 255, 0.3);
            }
        </style>
    </head>
    <body class="bg-gray-900 text-gray-200">
        <%- include("../../components/navs/user-navbar.ejs") %>

        <main>
            <div class="background-container">
                <img src="/assets/images/login-bg.jpg" alt="Signup Background" />
            </div>
            <div class="background-overlay"></div>

            <div class="content-container">
                <div class="sm:mx-auto sm:w-full sm:max-w-md">
                    <h2 class="text-center text-3xl font-extrabold text-gray-100">
                        Join Us in Reducing Food Waste
                    </h2>
                </div>
                <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md px-8">
                    <div class="">
                        <div class="glassmorphism">
                            <form id="signup-form" class="space-y-6">
                                <div>
                                    <label class="block text-sm font-medium text-gray-800"
                                        >Full Name</label
                                    >
                                    <input
                                        type="text"
                                        name="name"
                                        required
                                        class="w-full p-2 border rounded-md text-black"
                                        placeholder="Enter your full name" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-800"
                                        >Email</label
                                    >
                                    <input
                                        type="email"
                                        name="email"
                                        required
                                        class="w-full p-2 border rounded-md text-black"
                                        placeholder="Enter your email" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-800"
                                        >Phone</label
                                    >
                                    <input
                                        type="tel"
                                        name="mobile"
                                        required
                                        maxlength="10"
                                        class="w-full p-2 border rounded-md text-black"
                                        placeholder="Enter your phone number" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-800"
                                        >Address</label
                                    >
                                    <textarea
                                        name="address"
                                        rows="2"
                                        class="w-full p-2 border rounded-md text-black"
                                        placeholder="Enter your address"></textarea>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-800"
                                        >Password</label
                                    >
                                    <input
                                        type="password"
                                        name="password"
                                        required
                                        class="w-full p-2 border rounded-md text-black"
                                        placeholder="Enter a strong password" />
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-800"
                                        >Confirm Password</label
                                    >
                                    <input
                                        type="password"
                                        name="confirm_password"
                                        required
                                        class="w-full p-2 border rounded-md text-black"
                                        placeholder="Enter a strong password" />
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-800"
                                        >Organization Name (For Recipient - Optional)</label
                                    >
                                    <textarea
                                        type="text"
                                        name="organization_name"
                                        required
                                        class="w-full p-2 border rounded-md text-black"
                                        placeholder="Enter a Organization Name"></textarea>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-800"
                                        >Select Role</label
                                    >
                                    <select
                                        type="role"
                                        name="role"
                                        required
                                        class="w-full p-2 border rounded-md text-black">
                                        <option value="" selected>--Select--</option>
                                        <option value="donor">Donor</option>
                                        <option value="recipient">Recipient</option>
                                    </select>
                                </div>
                                <div>
                                    <button
                                        type="submit"
                                        id="signup-btn"
                                        class="w-full p-2 bg-green-600 text-white rounded-md hover:bg-green-700">
                                        Sign Up
                                    </button>
                                </div>
                                <div class="text-center">
                                    <p>
                                        Already have an account?
                                        <a href="/auth/login" class="text-green-500">Login</a>
                                    </p>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </body>
</html>
