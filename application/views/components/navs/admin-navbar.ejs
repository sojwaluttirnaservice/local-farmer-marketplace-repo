<!-- Sidebar -->
<aside
    id="sidebar"
    class="w-[250px] min-h-screen p-6 bg-gradient-to-b from-gray-800 to-gray-900 text-white shadow-xl transform -translate-x-full transition-transform duration-300 ease-in-out z-50 lg:translate-x-0">
    <!-- Sidebar Header -->
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold tracking-wide uppercase text-gray-100">Admin Panel</h2>
        <button onclick="" class="text-gray-400 text-2xl focus:outline-none lg:hidden">
            &times;
        </button>
    </div>

    <!-- Navigation -->
    <nav class="space-y-1">
        <a
            href="/admin/dashboard"
            class="flex items-center space-x-3 p-3 rounded-lg transition duration-300 ease-in-out hover:bg-gray-700">
            <i class="fas fa-tachometer-alt text-blue-300"></i>
            <span class="text-sm font-medium text-gray-100">Dashboard</span>
        </a>

        <a
            href="/farmers/signup"
            class="flex items-center space-x-3 p-3 rounded-lg transition duration-300 ease-in-out hover:bg-gray-700">
            <i class="fas fa-user-plus text-green-300"></i>
            <span class="text-sm font-medium text-gray-100">Add Farmer</span>
        </a>

        <a
            href="/products/add"
            class="flex items-center space-x-3 p-3 rounded-lg transition duration-300 ease-in-out hover:bg-gray-700">
            <i class="fas fa-seedling text-yellow-300"></i>
            <span class="text-sm font-medium text-gray-100">Add Product</span>
        </a>

        <a
            href="/users"
            class="flex items-center space-x-3 p-3 rounded-lg transition duration-300 ease-in-out hover:bg-gray-700">
            <i class="fas fa-users text-purple-300"></i>
            <span class="text-sm font-medium text-gray-100">Users</span>
        </a>

        <a
            hidden
            href="/orders"
            class="flex items-center space-x-3 p-3 rounded-lg transition duration-300 ease-in-out hover:bg-gray-700">
            <i class="fas fa-box text-pink-300"></i>
            <span class="text-sm font-medium text-gray-100">Orders</span>
        </a>

        <!-- Logout Button -->
        <button
            type="button"
            id="logout-btn"
            class="flex items-center text-red-400 space-x-3 p-3 rounded-lg transition duration-300 ease-in-out hover:bg-red-700 hover:text-white">
            <i class="fas fa-sign-out-alt"></i>
            <span class="text-sm font-medium">Logout</span>
        </button>
    </nav>

    <!-- Admin Profile -->
    <div
        hidden
        class="absolute bottom-6 left-6 right-6 flex items-center bg-gray-700 p-4 rounded-lg gap-4">
        <img
            src="https://via.placeholder.com/50"
            alt="Admin Avatar"
            class="rounded-full w-12 h-12 border-2 border-gray-400" />
        <div>
            <p class="font-medium text-gray-100">Admin Name</p>
            <p class="text-xs text-gray-300">admin@example.com</p>
        </div>
    </div>
</aside>
